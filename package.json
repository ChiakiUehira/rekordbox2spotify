{
  "name": "rekordbox2spotify",
  "version": "0.1.0",
  "description": "Sync rekordbox playlists to Spotify with multi-stage matching (ID3 ISRC + normalized title/artist + fuzzy)",
  "license": "MIT",
  "author": "Chiaki Uehira",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChiakiUehira/rekordbox2spotify.git"
  },
  "keywords": [
    "rekordbox",
    "spotify",
    "dj",
    "playlist",
    "sync",
    "cli"
  ],
  "private": true,
  "type": "module",
  "bin": {
    "rekordbox2spotify": "./src/cli.ts"
  },
  "scripts": {
    "rekordbox2spotify": "bun run src/cli.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "fast-xml-parser": "^4.4.0",
    "fastest-levenshtein": "^1.0.16",
    "music-metadata": "^11.12.3",
    "ora": "^8.0.1",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  }
}
